rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // El partido acepta apuestas hasta 10 minutos antes del inicio.
    // Si el partido no existe o no tiene startMs, la lectura falla y se deniega.
    function bettingOpen(matchId) {
      let m = get(/databases/$(database)/documents/matches/$(matchId)).data;
      return m.isFinished == false
        && request.time.toMillis() < m.startMs - 10 * 60 * 1000;
    }

    // Deadline global (campeón y orden de grupos): 10 min antes del primer partido.
    // Requiere el doc config/settings con bettingDeadlineMs (lo crea el script de backfill/seed).
    function tournamentOpen() {
      return request.time.toMillis()
        < get(/databases/$(database)/documents/config/settings).data.bettingDeadlineMs;
    }

    // Perfil: lectura pública (ranking), escritura solo el dueño.
    // points solo lo modifica el Admin SDK; championId se congela al iniciar el torneo.
    match /profiles/{userId} {
      allow read: if true;
      allow create: if isOwner(userId)
        && request.resource.data.points == 0
        && request.resource.data.championId == null;
      allow update: if isOwner(userId)
        && request.resource.data.points == resource.data.points
        && (request.resource.data.championId == resource.data.championId
            || tournamentOpen());
      allow delete: if false;
    }

    // Apuestas de partidos: una por usuario/partido (ID forzado) y solo antes del cierre
    match /bets/{betId} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && betId == request.auth.uid + '_' + request.resource.data.matchId
        && bettingOpen(request.resource.data.matchId);
      allow delete: if false;
    }

    // Apuestas de penaltis (eliminatorias): mismas restricciones
    match /penalty_bets/{betId} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && betId == request.auth.uid + '_' + request.resource.data.matchId
        && bettingOpen(request.resource.data.matchId);
      allow delete: if false;
    }

    // Apuestas de grupos: una por usuario y grupo, solo antes del primer partido
    match /group_bets/{betId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && betId == request.auth.uid + '_' + request.resource.data.groupName
        && tournamentOpen();
      allow update, delete: if false;
    }

    // Resultados oficiales y settings — solo administrador vía Admin SDK/consola
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Partidos: lectura para todos; escritura solo Admin SDK (scripts de sincronización)
    match /matches/{matchId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
