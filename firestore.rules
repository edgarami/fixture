rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Perfil: lectura pública (ranking), escritura solo el dueño
    match /profiles/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // Apuestas de partidos
    match /bets/{betId} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Apuestas de penaltis (eliminatorias)
    match /penalty_bets/{betId} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Apuestas de grupos (una por usuario y grupo)
    match /group_bets/{betId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Resultados oficiales (campeón, orden de grupos) — solo administrador vía consola
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Partidos: lectura para todos; escritura solo Admin SDK (scripts de sincronización)
    match /matches/{matchId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
